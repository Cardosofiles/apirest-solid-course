NODE_ENV=development
PORT=3333

# ✅ banco consistente entre POSTGRES_DB e DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gympass_style_db?schema=public

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gympass_style_db
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@local.com
PGADMIN_PASSWORD=admin@123